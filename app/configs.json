{
  "mcp": {
    "local_servers_log_level": "WARNING"
  },
  "image_generation": {
    "deliverables_path": "/agents/meme_gen/deliverables",
    "assets_path": "/agents/meme_gen/assets",
    "image_size": "1024x1792"
  },
  "used_topics": {
    "cache_path": "/agents/meme_gen/persistence/used_topics_cache.pkl",
    "cache_ttl_hours": 12
  },
  "web_search": {
    "client": "Tavily",
    "cache_path": "/agents/meme_gen/persistence/web_search_cache.pkl",
    "cache_ttl_minutes": 180,
    "quota_per_node": 2
  },
  "remote_credentials": {
    "OPENAI_API_KEY": "/Memegen/Credentials/OpenApi",
    "SERPERDEV_API_KEY": "/MemeGen/Credentials/SerperDev",
    "TAVILY_API_KEY": "/MemeGen/Credentials/Tavily",
    "LANGSMITH_API_KEY": "/MemeGen/Credentials/LangSmith",
    "X_CONSUMER_KEY": "/MemeGen/Credentials/TwitterX/ConsumerKey",
    "X_CONSUMER_SECRET": "/MemeGen/Credentials/TwitterX/ConsumerSecret",
    "X_ACCESS_TOKEN": "/MemeGen/Credentials/TwitterX/AccessToken",
    "X_ACCESS_TOKEN_SECRET": "/MemeGen/Credentials/TwitterX/AccessTokenSecret"
  },
  "flags": {
    "raise_exception_on_critical_failure": false,
    "agent_log_verbose": false,
    "enable_publishing": true,
    "enable_image_generation": true
  }
}